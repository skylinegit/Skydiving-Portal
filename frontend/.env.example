# Skyline Skydiving Portal — frontend env template
#
# Copy this file to frontend/.env.local and fill in the real values.
# Both .env.local and .env are gitignored and must NEVER be committed.

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
# Base URL of the FastAPI backend (no trailing slash).
# - Leave empty (or remove this line) to fall back to MOCK mode. The portal
#   works fully without a running backend in mock mode.
# - Set to http://localhost:8000 for local backend development.
# - Set to the deployed backend URL in staging / production.
NEXT_PUBLIC_API_BASE_URL=

# Example for local dev with the backend running:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
