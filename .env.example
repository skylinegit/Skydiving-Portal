# Skyline Skydiving Portal environment template
# Copy to .env.local in frontend/ for local dev.

# Public base URL of the FastAPI backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Set to "mock" to use the in-memory mock API (no backend required).
# Set to "live" to call NEXT_PUBLIC_API_BASE_URL.
NEXT_PUBLIC_API_MODE=mock
