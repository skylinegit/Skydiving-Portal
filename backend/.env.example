# Skyline Skydiving Portal — backend env template
#
# Copy this file to backend/.env and fill in the real values.
# backend/.env is gitignored and must NEVER be committed.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Async PostgreSQL connection string (SQLAlchemy + asyncpg driver).
# Note the `+asyncpg` and `?ssl=require` parts — both are required for
# DigitalOcean Managed Postgres.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:25060/defaultdb?ssl=require

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=development              # development | staging | production
APP_NAME=Skyline Portal API

# -----------------------------------------------------------------------------
# Sessions / cookies
# -----------------------------------------------------------------------------
SESSION_COOKIE_NAME=skyline_session
SESSION_TTL_DAYS=30
# Production MUST be true. Set false only for local HTTP testing.
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
# Leave empty in development. In production, set to ".skylineevents.co.uk"
# (or whichever domain you serve frontend + backend from).
SESSION_COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# Token TTLs
# -----------------------------------------------------------------------------
PASSWORD_RESET_TTL_MINUTES=30
EMAIL_CHANGE_TTL_MINUTES=60

# -----------------------------------------------------------------------------
# URLs / CORS
# -----------------------------------------------------------------------------
# Used when building reset and email-change links in the emails we send.
FRONTEND_URL=http://localhost:3000
# JSON list of origins allowed to call the API. Must match exactly (scheme + host + port).
CORS_ORIGINS=["http://localhost:3000"]

# -----------------------------------------------------------------------------
# N8N webhook endpoints (CRM bridge)
# -----------------------------------------------------------------------------
N8N_BASE_URL=https://n8n.skylineevents.co.uk
N8N_WEBHOOK_TOKEN=

# -----------------------------------------------------------------------------
# Email (transactional). Leave empty in dev — emails will be logged to stdout.
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@skylineevents.co.uk
